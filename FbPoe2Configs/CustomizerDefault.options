            QuickUI(IdMagicT3RB, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            QuickUI(IdMagicT2RB, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            Description("Rank C");
            QuickUI(IdMagicT4RC, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Gear, Magic, Tier 4-5, Rank C");
            QuickUI(IdMagicT3RC, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            QuickUI(IdMagicT2RC, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            Description("Any rank high-tier item (only if not matched by rules above)");
            QuickUI([0.0, "Magic Tiers, Remaining, Tier 5", "ut->magic;anyremaining5gear"] "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Other T5 magics, any rank");
            QuickUI([0.0, "Magic Tiers, Remaining, Tier 4", "ut->magic;anyremaining4gear"] "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Other T4 magics, any rank");
        }

        Section("NORMAL BASES + NO TIER MAGICS", "buckler04.webp")
        {
            Description("Crafting bases with ideal itemlevel (82). The itemlevel allows these bases to roll the highest tiers of mods, that can't be found on lower levels");
            QuickUI(C1Ideal, "SD", ["AreaLevel","ItemLevel", "UnidentifiedItemTier", "Rarity"], "Rank A Crafting Bases (LVL82+)");
            QuickUI(C2Ideal, "SD", ["AreaLevel","ItemLevel", "UnidentifiedItemTier", "Rarity"], "Rank B Crafting Bases (LVL82+)");
            QuickUI(C3Ideal, "SD", ["AreaLevel","ItemLevel", "UnidentifiedItemTier", "Rarity"], "Rank C Crafting Bases (LVL82+)");
            Description("The bases below are designed to be shown when in appropriate zone levels. You'll see T3 bases when in low waystones (because these are the best available at that level)");
            QuickUI(C1, "SD", ["AreaLevel","ItemLevel", "UnidentifiedItemTier", "Rarity"], "Rank A Bases (any level)"););
            QuickUI(C2OnLvl, "SD", ["AreaLevel","ItemLevel", "UnidentifiedItemTier", "Rarity"], "Rank B Bases (70-75)");
            QuickUI(C3OnLvl, "SD", ["AreaLevel","ItemLevel", "UnidentifiedItemTier", "Rarity"], "Rank C Bases (65-70)");
        }

        Title("Control Tiering:");
        BaseTypeMatrix(true,
            "Tier 1", R1Top, R1Other, C1Ideal, C1, IdRareT4RA, IdRareT3RA, IdRareT2RA, IdMagicT4RA, IdMagicT3RA, IdMagicT2RA,
            "Tier 2", R2Top, R2A1, R2Other, C2Ideal, C2OnLvl, IdRareT4RB, IdRareT3RB, IdRareT2RB, IdMagicT4RB, IdMagicT3RB, IdMagicT2RB,
            "Tier 3", R3A1, R3A2, R3Other, R3Top, C3Ideal, C3OnLvl, IdRareT4RC, IdRareT3RC, IdRareT2RC, IdMagicT4RC, IdMagicT3RC, IdMagicT2RC,
            "Tier 4", R4A1, R4A2, R4Other
        );
    }

    Section("Exceptional & Identified Rules", "buckler09.webp")
    {
        Section("Exceptional: Quality/Sockets", "buckler09.webp") {

            Description("If an S or A tier unique base drops with exceptional number of sockets or quality it's highlighted by this rule. This rule will be further refined when more data is known");

            Search Chancing(0.0, "Chancing 3 Sockets", "exotic->exceptional;chancingoversocket3") { }
            Search Chancing(0.0, "Chancing 2 Sockets", "exotic->exceptional;chancingoversocket2") { }
            Search QualT1(1.0, "Overqualitied a", "exotic->exceptional;overqual1q1") { }
            Search QualAny(1.0, "Overqualitied b", "exotic->exceptional;overqual1q2") { }

            Search SockAny(1.0, "Oversocketed Tier 2a", "exotic->exceptional;oversockt2s3") { }
            Search SockAny(1.0, "Oversocketed Tier 2b", "exotic->exceptional;oversockt2s2") { }
            Search SockT1(1.0, "Oversocketed Tier 1a", "exotic->exceptional;oversockt1s2") { }
            Search SockT1(1.0, "Oversocketed Tier 1b", "exotic->exceptional;oversockt1s3") { }

            QuickUI([0.0, "Chancing Overquality", "exotic->exceptional;chancingoverqual"], "SH", ["Quality"], "Chance Bases: Overquality", ["gearInclDisabled", "SO"]);

            QuickUI(Chancing, "SD", [], "Chance Bases: Oversocket", ["gearInclDisabled", "SO"]);

            Description("Items with exceptional amount of quality or sockets and potentially very valuable bases are highlighted by these rules");
            QuickUI(SockT1, "SD", ["ItemLevel"], "Value-bases: Oversocket", ["gearInclDisabled", "SO"]);
            QuickUI(QualT1, "SD", ["Quality", "ItemLevel"], "Value-bases: High Overquality", ["gearInclDisabled", "SO"]);

            Description("Any other normal, magic or rare exceptional item will get caught by the rules below.");
            QuickUI(SockAny, "SD", ["ItemLevel"], "Any Oversocket Exceptional Item");
            QuickUI(QualAny, "SD", ["Quality", "ItemLevel"], "Any Overquality Exceptional Item");

            Description("These rules have lower priority than S and A tier uniques");
            QuickUI([0.0, "Exceptional Overquality Uniques", "uniques;overqualityuniques"], "SH", ["Quality"], "Uniques: Overquality");
            Search UniqExcSock(0.0, "Exceptional Oversocket Uniques 1", "uniques;oversocketuniques1") { }
            Search UniqExcSock(0.0, "Exceptional Oversocket Uniques 2", "uniques;oversocketuniques2") { }
            QuickUI(UniqExcSock, "SH", [], "Uniques: Oversocket");
        }

        Section("Identified Mod Filtering", "IdentifiedItem") {
            Description("Identified items with one or multiple desired T1 mods are highlighted here. There intent is to be used for recombinations");
            QuickUI([0.0, "Recombinator Mods, Boots", "exoticmods;cmboots"], "SH", ["Mods"]);
            QuickUI([0.0, "Recombinator Mods, Amulets", "exoticmods;cmamulets"], "SH", ["Mods"]);
            QuickUI([0.0, "Recombinator Mods, Caster Weapons", "exoticmods;cmcasterweapons"], "SH", ["Mods"]);
            QuickUI([0.0, "Recombinator Mods, Sceptres", "exoticmods;cmsceptres"], "SH", ["Mods"]);
            QuickUI([0.0, "Recombinator Mods, Ranged", "exoticmods;cmranged"], "SH", ["Mods"]);
            QuickUI([0.0, "Recombinator Mods, Spears", "exoticmods;cmspears"], "SH", ["Mods"]);
            QuickUI([0.0, "Recombinator Mods, 2-Hand", "exoticmods;cm2handed"], "SH", ["Mods"]);
        }

        Section("Breach rings", "BreachRing")
        {
            QuickUI([0.0, "Breach Rings, high level", "exoticbases;commonexoticbaseshigh"], "SH", ["Rarity", "ItemLevel", "Identified", "UnidentifiedItemTier"]);
            QuickUI([0.0, "Breach Rings", "exoticbases;commonexoticbases"], "SH", ["Rarity", "ItemLevel", "Identified", "UnidentifiedItemTier"]);
        }

        Section("Optional Rules", "Shrine_Sceptre_Fire_inventory_icon")
        {
            QuickUI([0.0, "ILVL81 Caster Items", "endgame->normalcraft->any;minionsceptresoptional"], "SD", ["ItemLevel", "CasterWeaponClasses", "Rarity", "UnidentifiedItemTier"], "", ["gear", "SAO"]);
            QuickUI([0.0, "ILVL81 Crafting Wands", "endgame->normalcraft->extra;wands"], "SD", ["ItemLevel", "CasterWeaponClasses", "Rarity", "UnidentifiedItemTier"], "", ["gear", "SAO"]);
        }
