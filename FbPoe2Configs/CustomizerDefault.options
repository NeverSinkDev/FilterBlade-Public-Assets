            QuickUI([0.0, "Endgame Crafting Decorator, Quality 1", "endgame->normalcraft->decorator;qualitydecorator1"], "SD", ["AllGearClasses", "Rarity", "Quality"], "If the item has 10%+ quality...");
            QuickUI([0.0, "Endgame Crafting Decorator, Quality 2", "endgame->normalcraft->decorator;qualitydecorator2"], "SD", ["AllGearClasses", "Rarity", "Quality"], "If the item has 1%+ quality...");
            QuickUI([0.0, "Endgame Crafting Decorator, normal", "endgame->normalcraft->decorator;regulargeardecorator"], "SD", ["AllGearClasses", "Rarity"], "Also Every item...");
        }
