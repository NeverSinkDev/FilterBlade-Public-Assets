            QuickUI(R3A1, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank C Rares: LVL75+");
            QuickUI(R4A1, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank D Rares: LVL75+");
            QuickUI(R5A1, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Untiered Rares: LVL75+");
        }

        Section("NO-TIER RARES: Lower Waystones", "buckler05.webp")
        {
            Description("New item types become available once you push into higher waystones. Those have better stats than previous versions. The tierlist highlights the most relevant bases in the current waystone. This section defines visibility in lower waystones (under level 75).");

            QuickUI(R2Other, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank B: LVL65-74 (TOP OF THE LINE)");

            QuickUI(R3Other, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank C: LVL65-69 (TOP OF THE LINE)");
            QuickUI(R3A2, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank C: LVL70-74 (VIABLE)");

            QuickUI(R4Other, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank D: LVL65-69 (VIABLE)");
            QuickUI(R4A2, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Rank D: LVL70-74 (POOR)");

            QuickUI(R5A2, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Untiered: LVL70-74+ (POOR)");
            QuickUI(R5Other, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Untiered: LVL65-69+ (POOR)");
        }

        Section("RARES: TIER 2+ ", "buckler09.webp") {
            Description("Rank A");
            QuickUI(IdRareT4RA, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Gear, Rare, Tier 4-5, Rank A");
            QuickUI(IdRareT3RA, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            QuickUI(IdRareT2RA, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
