    Section("Uniques", "Alphas_Howl_inventory_icon", "E") {
        // generated via manualUtil_GenerateOptFileTierListCode(); util function!
        Function UniquesFunc($s, $shd = "SHD", $text, $descr = false) { QuickUI($s, $shd, [], $text, ["GearPlusFlasks", "O"], $descr); }
        TierListToolBar("Uniques");

        Title("Predictable Tiers");
        UniquesFunc([0.0, "Uniques Tier 1", "uniques;t1"], "SH", "S Tier", "Tier 1 uniques are always an expensive and lucky find!");
        UniquesFunc([0.0, "Uniques Tier 2", "uniques;t2"], "SH", "A Tier", "Tier 2 uniques are always fairly expensive, but can be even more valuable with some lucky rolls");
        UniquesFunc([0.0, "Uniques Tier 3", "uniques;t3"], "SH", "B+C Tier", "These are highly roll dependent. Keep your filter updated, especially if you want to hide this section!");
        UniquesFunc([0.0, "Uniques EarlyLeague", "uniques;earlyleague"], "SHD", "D TIER - Early League Uniques", "Expensive or interesting at the start of the new league, but lose value VERY fast! This tier stays empty, after the first days of the new league");
        UniquesFunc([0.0, "Uniques Hideable", "uniques;hideable"], "SH", "D TIER - LOW VALUE", "These uniques are worth very little. Keep your filter updated, if you want to hide this section! Hiding this section at the start of new leagues and in SSF is a bad idea.");

        Title("High Variety Tiers");
        UniquesFunc([0.0, "Uniques MultiSpecial High", "uniques;multispecialhigh"], "SH", "High Variety - top multi-bases", "Multiple uniques share the same base: very valuable uniques AND cheap uniques. The filter can't say which one dropped. Always check these! There's a VERY small chance for these to be VERY expensive");
        UniquesFunc([0.0, "Uniques MultiSpecial", "uniques;multispecial"], "SH", "High Variety - multi-bases", "Multiple uniques share the same base: very valuable uniques AND cheap uniques. The filter can't say which one dropped. Always check these! There's a small chance for these to be expensive");
        UniquesFunc([0.0, "Uniques Tier 3 Boss", "uniques;t3boss"], "SH", "High Variety - boss-drops", "A potentially expensive unique version of this item drops ONLY from bosses! The world drop unique is fairly cheap! You can hide this tier, BUT remember to check the hidden items dropped by bosses!");

        // new tiers
        Conditional("?UniquesNewTier") { }
        ElementAdder_Tier("?UniquesNewTier", "UniquesFunc");

        // hide tier
        Conditional("?UniquesNewTiersHidden") { }
        ElementAdder_Tier("?UniquesNewTiersHidden", null, true, "GearPlusFlasks", "OH");
    }

    Section("Chancing", "Astramentis_inventory_icon") {
        // generated via manualUtil_GenerateOptFileTierListCode(); util function!
        Function ChancingFunc($s, $shd = "SHD", $text) { QuickUI($s, $shd, ["AreaLevel"], $text, ["gearPlusFlasks", "OS"]); }
        TierListToolBar();

        Description("An 'Orb of Chance' has a chance to turn a normal item into a unique. The chances for that are fairly low, but it can be pretty thrilling and profitable if you hit the lottery. The following section suggests potential chancing bases.<br> Only non-boss drops can be chanced. Acquiring certain bases is harder than finding the chance orbs. So some very profitable chance bases can be VERY expensive:");

        ChancingFunc([0.0, "Chancing bases Tier S", "chancing;chances"], "SD");
        ChancingFunc([0.0, "Chancing bases Tier A", "chancing;chancea"], "SD");
        ChancingFunc([0.0, "Chancing bases", "chancing;chanceany"], "SD");

        // new tiers
        Conditional("?ChancingNewTier") { }
        ElementAdder_Tier("?ChancingNewTier", "ChancingFunc");
    }

