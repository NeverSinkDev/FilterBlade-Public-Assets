    Section("Gold", "Gold_inventory_icon") {
        Description("Gold can be hidden and will still be auto-picked up if you walk next to it.");

        Function GoldFunc($s, $shd = "SHD", $text) { QuickUI($s, $shd, ["StackSize", "AreaLevel"], $text); }

        GoldFunc([0.0, "Gold Pile: Gigantic", "gold;stack3"], "SH");
        GoldFunc([0.0, "Gold Pile: Large", "gold;stack2"], "SH");
        GoldFunc([0.0, "Gold Pile: Medium (Endgame)", "gold;stack1"], "SH");
        GoldFunc([0.0, "Gold Pile: Small", "gold;any"], "SH");

        GoldFunc([0.0, "Gold Pile: Medium (Campaign) 1", "gold;stack1lvl"], "SH", "Gold Pile: Medium (Campaign Act 1)");
        GoldFunc([0.0, "Gold Pile: Medium (Campaign) 2", "gold;stack2lvl"], "SH", "Gold Pile: Medium (Campaign Act 2-3)");
        GoldFunc([0.0, "Gold Pile: Medium (Campaign)", "gold;stack3lvl"], "SH", "Gold Pile: Medium (Campaign Later Acts)");

        // new tiers
        Conditional("?GoldNewTier") { Show; BaseType == "Gold"; StackSize >= 1337; SetTextColor 200 200 0; SetBorderColor 200 200 0; }
        ElementAdder_Tier("?GoldNewTier", "GoldFunc");
    }

    Section("Current League: Fate of the Vaal", "Vaal Orb") {
        Title("Twice-Corruption Outcomes");
        QuickUI([0.0, "twice corrupted rare items", "exotic->state;twicecorruptedrare"], "SH", []);
        QuickUI([0.0, "twice corrupted magic items", "exotic->state;twicecorruptedmagic"], "SH", []);
        QuickUI([0.0, "twice corrupted uniques", "uniques;twicecorrupteduniques"], "SH", []); // todo
        QuickUI([0.0, "twice corrupted gems: 21/23", "gems;upgradedgemstwice"], "SH", []); // todo
        QuickUI([0.0, "twice corrupted gems", "gems;upgradedgemslevel"], "SH", []); // todo
        Title("Vaal-Specific Uniques");
        QuickUI([0.0, "uniques with a corrupted vaal mod", "uniques;vaalmodunique"], "SH", []); // todo
        QuickUI([0.0, "vaal-origin uniques", "uniques;vaaltypeuniques"], "SD", []); // todo
        QuickUI([0.0, "Unhidable Event Outcome items", "special->alwaysshow;any"], "S", []);
        Description("All other items have been integrated into their respective tierlists.");
    }

    Section("Highlight specific bases", "Firefly") {

        Description("Quickly highlight bases by adding a custom rule! If you need more power and options, there's a lot more custom rules lower in the customizer");

        Function CondShowBaseQuick ($s, $shd = "SD", $title)
        {
            QuickUI($s, $shd, ["RarityU", "ItemLevel", "Corrupted", "Stats_Rarity", "UnidentifiedItemTier"], $title, ["rarityItems", "OS"]);
        }

        Conditional("?CQuickEndgameCustomRule1", ["c3.gear.chancing"], null, 4190) { Show; BaseType == "Gemini Bow" "Primed Quiver"; SetBorderColor 200 0 0; SetBackgroundColor 60 0 0; SetFontSize 40; ItemLevel >= 68; Rarity Normal Magic; Corrupted False; Mirrored False; }
        ElementAdder_Tier("?CQuickEndgameCustomRule1", "CondShowBaseQuick");
    }
}

Chapter() {
    SectionTitle("Endgame Rares & Crafting");

    Section("Hide Armour Classes & Weapon Types", "annullorb.webp") {
        Title("Normal/Magic");
        QuickUI([0.0, "Endgame Hide, Crafting, Armour", "endgame->conditionalhiders->crafting;arhider"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Armour");
        QuickUI([0.0, "Endgame Hide, Crafting, Evasion", "endgame->conditionalhiders->crafting;evhider"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Evasion");
        QuickUI([0.0, "Endgame Hide, Crafting, ES", "endgame->conditionalhiders->crafting;eshider"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Energy Shield");
        QuickUI([0.0, "Endgame Hide, Crafting, Ar-Ev", "endgame->conditionalhiders->crafting;arevhider"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Hybrid Armour+Evasion");
        QuickUI([0.0, "Endgame Hide, Crafting, Ar-ES", "endgame->conditionalhiders->crafting;areshider"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Hybrid Armour+ES");
        QuickUI([0.0, "Endgame Hide, Crafting, ES-EV", "endgame->conditionalhiders->crafting;eveshider"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Hybrid Evasion+ES");
        Warning("Open the rule and select the weapons you DON'T want. Otherwise it'll hide ALL weapons.");
        QuickUI([0.0, "Endgame Hide, Crafting, WeaponTypes", "endgame->conditionalhiders->crafting;hideweaponsbytype"], "DH", ["ItemLevel", "Sockets", "Quality", "Rarity", "UnidentifiedItemTier", "WeaponAndOffhandClasses"], "Hide Weapon/Offhand Classes");
        Title("Rares");
        QuickUI([0.0, "Endgame Hide, Rare, Armour", "endgame->conditionalhiders->rare;arhider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Armour");
        QuickUI([0.0, "Endgame Hide, Rare, Evasion", "endgame->conditionalhiders->rare;evhider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Evasion");
        QuickUI([0.0, "Endgame Hide, Rare, ES", "endgame->conditionalhiders->rare;eshider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Energy Shield");
        QuickUI([0.0, "Endgame Hide, Rare, Ar-Ev", "endgame->conditionalhiders->rare;arevhider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Hybrid Armour+Evasion");
        QuickUI([0.0, "Endgame Hide, Rare, Ar-ES", "endgame->conditionalhiders->rare;areshider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Hybrid Armour+ES");
        QuickUI([0.0, "Endgame Hide, Rare, ES-EV", "endgame->conditionalhiders->rare;eveshider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier", "ArmourClasses"], "Hide: Hybrid Evasion+ES");
        QuickUI([0.0, "Endgame Hide, Rare, Identified", "conditionalhide;idhider"], "DH", ["ItemLevel", "Sockets", "Quality", "UnidentifiedItemTier"], "Hide: Identified");
