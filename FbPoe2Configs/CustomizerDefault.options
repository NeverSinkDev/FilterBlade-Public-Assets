            QuickUI(IdRareT3RC, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            QuickUI(IdRareT2RC, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            Description("Any rank high-tier item (only if not matched by rules above)");
            QuickUI([0.0, "Rare Tiers, Remaining, Tier 5", "ut->rare;anyremaining5gear"] "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Other T5 rares, any rank");
            QuickUI([0.0, "Rare Tiers, Remaining, Tier 4", "ut->rare;anyremaining4gear"] "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Other T4 rares, any rank");
        }

        Section("MAGICS: Tier 2+", "buckler09.webp") {
            Description("Rank A");
            QuickUI(IdMagicT4RA, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"], "Gear, Magic, Tier 4-5, Rank A");
            QuickUI(IdMagicT3RA, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            QuickUI(IdMagicT2RA, "SH", ["ItemLevel", "AreaLevel", "UnidentifiedItemTier"]);
            Description("Rank B");
