Chapter() {
    SectionTitle("Misc.");

    Section("Add additional Show/Hide rules", "Firefly") {
        Description("Use this section to add exotic rules and exception. This section is NOT foolproof, you can accidentally hide valuable items by misusing it. With great power comes great responsibility.");

        Section("Add Basetype-Based Rules", "Firefly")
        {
            Function CondShowBase ($s, $shd = "SHD", $title)
            {
                QuickUI($s, $shd, ["CondTargetSelection", "AreaLevel", "UnidentifiedItemTier", "Stats_ALL"], $title, ["all", "OS"]);
            }

            Description("Give specific BaseTypes more highlighting here.");
            Conditional("?CUniversalCustomRuleB", ["c3.gear.chancing", "c0.start", "c4.gear.salvagable", "c7.jewels.generic.all", "c11.uniques.all", "c20.leveling.salvagable.all"], null, 4290) { Show; SetBackgroundColor 60 0 0; SetBorderColor 200 0 0; SetFontSize 40; AreaLevel >= 65; }
            ElementAdder_Tier("?CUniversalCustomRuleB", "CondShowBase");
        }

        Section("Add Class-Based Rules", "Firefly")
        {
            Function CondShowClass ($s, $shd = "SHD", $title)
            {
                QuickUI($s, $shd, ["CondTargetSelection", "ClassesWithRarity", "RarityU", "AreaLevel", "UnidentifiedItemTier", "Stats_ALL"], $title, ["all", "SOA"]);
            }

            Description("Give specific classes more highlighting here.");
            Conditional("?CUniversalCustomRuleC", ["c3.gear.chancing", "c0.start", "c4.gear.salvagable", "c7.jewels.generic.all", "c11.uniques.all", "c20.leveling.salvagable.all"], null, 4280) { Show; SetBackgroundColor 60 0 0; SetBorderColor 200 0 0; SetFontSize 40; AreaLevel >= 65; Rarity Normal Magic; }
            ElementAdder_Tier("?CUniversalCustomRuleC", "CondShowClass");
        }

        Section("Add Armour-Type-Based Rules", "Firefly")
        {
            Function CondShowArmourType ($s, $shd = "SHD", $title)
            {
                QuickUI($s, $shd, ["CondTargetSelection", "ItemType", "RarityU", "ArmourClasses", "AreaLevel", "UnidentifiedItemTier", "Stats_RareGear"], $title);
            }

            Conditional("?CUniversalCustomRuleArmourType", ["c3.gear.chancing", "c0.start", "c4.gear.salvagable", "c7.jewels.generic.all", "c11.uniques.all", "c20.leveling.salvagable.all"], null, 4270) { Show; SetBackgroundColor 60 0 0; SetBorderColor 200 0 0; SetFontSize 40; AreaLevel >= 65; Rarity Normal Magic; Class == "Body Armours" "Gloves" "Boots" "Helmets" "Shields"; }
            ElementAdder_Tier("?CUniversalCustomRuleArmourType", "CondShowArmourType");
        }

        Section("Add Mod-Filtering Rule", "Firefly")
        {
            Function CondFilterMod ($s, $shd = "SHD", $title)
            {
                QuickUI($s, $shd, ["CondTargetSelection", "RarityU", "ClassesWithRarity", "Identified", "Corrupted", "ItemLevel", "Stats_Rarity", "Mods"], $title, ["rarityItems", "SOA"]);
            }

            Description("Custom mod filtering. Note that you first need to select the correct classes, then add the mods you need.");
            Conditional("?CUniversalCustomRuleD", ["c3.gear.chancing", "c0.start", "c4.gear.salvagable", "c7.jewels.generic.all", "c11.uniques.all", "c20.leveling.salvagable.all"], null, 4260) { Show; SetBorderColor 220 50 150 255; SetTextColor 220 50 150 255; SetFontSize 45; Identified True; Corrupted False; Rarity Normal Magic Rare; HasExplicitMod "of Many"; PlayAlertSound 1 300; PlayEffect Red; MinimapIcon 0 Red Hexagon; }
            ElementAdder_Tier("?CUniversalCustomRuleD", "CondFilterMod");
        }
    }

