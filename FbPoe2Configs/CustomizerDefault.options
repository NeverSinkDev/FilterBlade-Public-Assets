            Function FlaskFunc($s, $shd = "SHD", $text) { QuickUI($s, $shd, ["Quality", "RarityNM", "ItemLevel", "AreaLevel", "Identified"], $text, ["Flasks", "SOA"]); }
            Conditional("?EgFlasksNewRule") { Show; BaseType == "Ultimate Life Flask"; Class "Flasks"; ItemLevel >= 65; SetTextColor 150 225 150; SetBorderColor 150 225 150; SetFontSize 40; }
