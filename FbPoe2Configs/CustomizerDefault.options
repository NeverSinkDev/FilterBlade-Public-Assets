            Search S_life(0.0, "Campaign Life Flask Progression 7", "leveling->flasks->life;t7") { }
            Search S_life(0.0, "Campaign Life Flask Progression 8", "leveling->flasks->life;t8") { }

            Search S_mana(0.0, "Campaign Mana Flask Progression 1", "leveling->flasks->mana;t1") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 2", "leveling->flasks->mana;t2") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 3", "leveling->flasks->mana;t3") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 4", "leveling->flasks->mana;t4") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 5", "leveling->flasks->mana;t5") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 6", "leveling->flasks->mana;t6") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 7", "leveling->flasks->mana;t7") { }
            Search S_mana(0.0, "Campaign Mana Flask Progression 8", "leveling->flasks->mana;t8") { }
            QuickUI(S_life, "SH", ["Quality", "RarityNM"], "Life Flask Progression");
            QuickUI(S_mana, "SH", ["Quality", "RarityNM"], "Mana Flask Progression");

            Function FlaskFunc($s, $shd = "SHD", $text) { QuickUI($s, $shd, ["Quality", "RarityNM", "ItemLevel", "AreaLevel"], $text, ["Flasks", "SOA"]); }
            Conditional("?LvlFlasksNewRule") { Show; BaseType == "Ultimate Life Flask"; Class "Flasks"; ItemLevel <= 65; SetTextColor 150 225 150; SetBorderColor 150 225 150; SetFontSize 40; }
            ElementAdder_Tier("?LvlFlasksNewRule", "FlaskFunc");
        }

        Section("Charms", "topazcharm.webp") {
            QuickUI([0.0, "Campaign Charms, Best", "leveling->charms;selected"], "SH", ["charms", "RarityNM", "ItemLevel"]);
            QuickUI([0.0, "Campaign Charms", "leveling->charms;any"], "SH", ["charms", "RarityNM", "ItemLevel"]);

            Function CharmFunc($s, $shd = "SHD", $text) { QuickUI($s, $shd, ["Quality", "RarityNM", "ItemLevel", "AreaLevel", "charms"], $text); }
            Conditional("?LvlCharmsNewRule") { Show; BaseType == "Golden Charm"; Class "Charms"; ItemLevel <= 65; SetTextColor 150 225 150; SetBorderColor 150 225 150; SetFontSize 40; }
            ElementAdder_Tier("?LvlCharmsNewRule", "CharmFunc");
        }
    }

    Section("Campaign Salvagable Items", "Artificers_Orb_inventory_icon") {
        QuickUI([0.0, "Campaign Salvable (High Quality, weapons)", "leveling->salvagable;quality2martialany"], "SH", ["Quality", "ItemLevel", "Width", "Height", "Rarity"], "Salvages into: 2+ Whetstones");
        QuickUI([0.0, "Campaign Salvable (High Quality, caster)", "leveling->salvagable;quality2casterany"], "SH", ["Quality", "ItemLevel", "Width", "Height", "Rarity"], "Salvages into: 2+ Etchers" );
        QuickUI([0.0, "Campaign Salvable (High Quality, armour)", "leveling->salvagable;quality2armorany"], "SH", ["Quality", "ItemLevel", "Width", "Height", "Rarity"], "Salvages into: 2+ Armourers");
        QuickUI([0.0, "Campaign Salvable (High Quality, flasks)", "leveling->salvagable;quality2flask"], "SH", ["Quality", "ItemLevel"], "Salvages into: 2+ Glassblower");
        QuickUI([0.0, "Campaign Salvable (Quality, weapons)", "leveling->salvagable;qualitymartialany"], "SH", ["Quality", "ItemLevel", "Width", "Height", "Rarity"], "Salvages into: 1 Whetstone");
        QuickUI([0.0, "Campaign Salvable (Quality, caster)", "leveling->salvagable;qualitycasterany"], "SH", ["Quality", "ItemLevel", "Width", "Height", "Rarity"], "Salvages into: 1 Etcher" );
        QuickUI([0.0, "Campaign Salvable (Quality, armour)", "leveling->salvagable;qualityarmorany"], "SH", ["Quality", "ItemLevel", "Width", "Height", "Rarity"], "Salvages into: 1 Armourer");
        QuickUI([0.0, "Campaign Salvable (Quality, flasks)", "leveling->salvagable;qualityflask"], "SH", ["Quality", "ItemLevel"], "Salvages into: 1 Glassblower");

        QuickUI([0.0, "Campaign Salvable (Sockets, small 1)", "leveling->salvagable;socketssmall1"], "SH", ["Sockets", "ItemLevel", "Width", "Height", "Rarity"], "Small Item: Artificer Shards (2x2)");
        QuickUI([0.0, "Campaign Salvable (Sockets, small 2)", "leveling->salvagable;socketssmall2"], "SH", ["Sockets", "ItemLevel", "Width", "Height", "Rarity"], "Small Item: Artificer Shards (1x4");
        QuickUI([0.0, "Campaign Salvable (Sockets, large 1)", "leveling->salvagable;socketsothers"], "SH", ["Sockets", "ItemLevel", "Width", "Height", "Rarity"], "Large Item: Artificer Shards");
