    Section("Special Rules", "GoldenKey") {
        Section("Relics") {
            // generated via manualUtil_GenerateOptFileTierListCode(); util function!
            Function RelicsFunc($s, $shd = "SHD", $text) { QuickUI($s, $shd, [], $text, ["C:Relics", "O"]); }
            TierListToolBar();

            RelicsFunc([1.0, "Relics", "relics->generic;any"], "SH", "S Tier");

            // new tiers
            Conditional("?RelicsNewTier") { }
            ElementAdder_Tier("?RelicsNewTier", "RelicsFunc");

            // hide tier
            Conditional("?RelicsNewTiersHidden") { }
            ElementAdder_Tier("?RelicsNewTiersHidden", null, true, "C:Relics", "OH");
        }

