            QuickUI([0.0, "Spirit Gems, Progression, Level 17", "gems->uncut;spiritgemprogression17"], "SH", ["AreaLevel", "ItemLevel"]);
            QuickUI([0.0, "Spirit Gems, Progression, Level 16", "gems->uncut;spiritgemprogression16"], "SH", ["AreaLevel", "ItemLevel"]);
            QuickUI([0.0, "Spirit Gems, Progression, Level 15", "gems->uncut;spiritgemprogression15"], "SH", ["AreaLevel", "ItemLevel"]);
            QuickUI([0.0, "Spirit Gems, Progression, Level 14", "gems->uncut;spiritgemprogression14"], "SH", ["AreaLevel", "ItemLevel"]);
            QuickUI([0.0, "Gems, Spirit, Endgame ", "gems->uncut;otherspiriteg"], "SH", ["AreaLevel", "ItemLevel"], "Other Lower Level Spirit Gems");
        }

        Section("ENDGAME: Support")
        {
            QuickUI([0.0, "Gems, Support, Endgame ", "gems->uncut;othersupporteg"], "SH", ["AreaLevel", "ItemLevel"], "Support Gems in T15+ maps");
            QuickUI([0.0, "Gems, Support, Endgame Early", "gems->uncut;supportearlymaps"], "SH", ["AreaLevel", "ItemLevel"], "Support Gems in lower maps");
